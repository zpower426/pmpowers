# Ensure shell scripts always have LF line endings
*.sh text eol=lf
hooks/session-start text eol=lf
hooks/pre-commit text eol=lf

# Common text files
*.md text eol=lf
*.json text eol=lf
*.js text eol=lf
*.cjs text eol=lf
*.mjs text eol=lf

# Explicitly mark binary files
*.png binary
*.jpg binary
*.gif binary
