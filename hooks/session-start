#!/usr/bin/env bash
# SessionStart hook for pmpowers plugin
# 动态加载并展示 24+ 项 PM 专业技能

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# 读取 using-pmpowers 内容作为导言
using_pmpowers_content=$(cat "${PLUGIN_ROOT}/skills/using-pmpowers/SKILL.md" 2>&1 || echo "Error reading using-pmpowers skill")

# 转义 JSON 字符串
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# 统计当前技能数量
skill_count=$(find "${PLUGIN_ROOT}/skills" -maxdepth 1 -type d | wc -l)
skill_count=$((skill_count - 1)) # 排除 skills 目录本身

using_pmpowers_escaped=$(escape_for_json "$using_pmpowers_content")

session_context="<EXTREMELY_IMPORTANT>\n🚀 **Pmpowers: Product-on-Purpose 流程引擎已就绪。**\n\n当前已加载 **${skill_count}** 项专家级 PM 技能，涵盖：客户发现、产品战略、原型制作、敏捷管理等全生命周期。\n\n**以下是你的 'pmpowers:using-pmpowers' 技能全文 - 这是你使用本引擎的交互宪章：**\n\n${using_pmpowers_escaped}\n</EXTREMELY_IMPORTANT>"

# 输出 JSON 格式注入
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
fi

exit 0
